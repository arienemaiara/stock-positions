{
  "name": "stock-positions",
  "private": true,
  "version": "0.0.0",
  "description": "Personal stock decision-support dashboard. Decision support, not advice.",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace server run build && npm --workspace web run build",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "reset": "npm --workspace server run reset",
    "cache:clear": "npm --workspace server run cache:clear"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
